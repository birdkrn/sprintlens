# === SprintLens Environment Variables ===

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# 메뉴 노출 설정 (true/false, 기본값: true)
MENU_DASHBOARD_ENABLED=true
MENU_SCHEDULE_ENABLED=true

# Flask Configuration
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false
FLASK_SECRET_KEY=change-me-to-random-secret-key

# Data Directory (DB 파일 저장 경로, 기본값: data/)
# DATA_DIR=data

# Cache Configuration (캐시 TTL: 분 단위)
CACHE_TTL_MINUTES=60

# 설정 페이지 비밀번호
SETTINGS_PASSWORD=change-me

# Jira Configuration (사내 구축 Jira Server v8.5.7, Basic Auth)
JIRA_BASE_URL=https://jira.your-company.com
JIRA_USERNAME=your_username
JIRA_PASSWORD=your_password
# 스프린트 보드 ID (Agile 보드 번호)
JIRA_BOARD_ID=
# 프로젝트 키 (예: G2M)
JIRA_PROJECT_KEY=

# QA_GMG Jira (같은 서버, 스프린트 보드 없이 JQL로 이슈 조회)
QA_GMG_JIRA_PROJECT_KEY=QA_GMG
# JQL 필터링 상태 (쉼표 구분, 워크플로우 영어 status명 사용)
QA_GMG_JQL_STATUSES=NEW ISSUE,ASSIGNED ISSUE,IN PROGRESS,IN PROGRESS(HOLD)
# QA_GMG 팀 멤버 (쉼표 구분, Jira displayName 기준)
QA_GMG_DEV_MEMBERS=
MENU_QA_GMG_ENABLED=true

# Confluence Configuration (사내 구축 Confluence Server v7.4.3, Basic Auth)
CONFLUENCE_BASE_URL=https://wiki.your-company.com
CONFLUENCE_USERNAME=your_username
CONFLUENCE_PASSWORD=your_password
# 스페이스 키
CONFLUENCE_SPACE_KEY=
# 스프린트 일정 페이지 ID
CONFLUENCE_SPRINT_PAGE_ID=

# 프로그램팀 멤버 (쉼표 구분, Jira displayName 기준)
PROGRAM_TEAM_MEMBERS=

# Gemini AI Configuration
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# Sidebar 외부 링크 (JSON 배열, icon: "board" | "doc" | "link")
# SIDEBAR_LINKS=[{"name": "메뉴이름", "url": "https://...", "icon": "board"}]
SIDEBAR_LINKS=

# Slack Configuration (매일 아침 스프린트 리포트)
# Incoming Webhook URL (슬랙 워크스페이스 설정에서 발급)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
# 리포트 발송 시각 (HH:MM, KST 기준)
SLACK_REPORT_TIME=09:00
# 슬랙 리포트 활성화 여부
SLACK_REPORT_ENABLED=false
# 대시보드 URL (슬랙 메시지에 '상세 보기' 링크로 포함)
SLACK_DASHBOARD_URL=http://your-server:5000/schedule
# 슬랙 리포트 섹션별 표시 갯수
SLACK_SHOW_IN_PROGRESS=99
SLACK_SHOW_DONE=5
SLACK_SHOW_WAITING=5
SLACK_SHOW_ADDED=5
