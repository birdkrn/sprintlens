{
  "name": "sprintlens",
  "private": true,
  "scripts": {
    "css:build": "tailwindcss -i ./static/src/input.css -o ./static/css/style.css --minify",
    "css:watch": "tailwindcss -i ./static/src/input.css -o ./static/css/style.css --watch",
    "dev": "concurrently \"npm run css:watch\" \"python app.py\""
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "daisyui": "^4.12.0",
    "htmx.org": "^2.0.8",
    "tailwindcss": "^3.4.0"
  }
}
